{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pharos-trustrail.local/schemas/trustrail-tools.schema.json",
  "title": "Pharos TrustRail Tool Inputs",
  "definitions": {
    "credential": {
      "type": "string",
      "enum": ["zk_kyc", "aml_screen", "agent_mandate_signature", "travel_rule_attestation"]
    },
    "action": {
      "type": "object",
      "required": ["action", "amountUsd", "asset", "recipientId", "purpose", "credentials"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["x402_payment", "rwa_purchase", "stablecoin_settlement", "treasury_payout", "contract_interaction"]
        },
        "amountUsd": { "type": "number", "minimum": 0 },
        "asset": { "type": "string", "minLength": 1 },
        "recipientId": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 500 },
        "contractAddress": { "type": "string" },
        "calldataHash": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "credentials": {
          "type": "array",
          "items": { "$ref": "#/definitions/credential" }
        }
      }
    },
    "preflightInput": {
      "type": "object",
      "required": ["policyId", "agentId", "action"],
      "properties": {
        "policyId": { "type": "string" },
        "agentId": { "type": "string" },
        "action": { "$ref": "#/definitions/action" }
      }
    },
    "x402ChallengeInput": {
      "allOf": [
        { "$ref": "#/definitions/preflightInput" },
        {
          "type": "object",
          "required": ["resource", "idempotencyKey"],
          "properties": {
            "resource": { "type": "string", "format": "uri" },
            "idempotencyKey": { "type": "string", "minLength": 8 }
          }
        }
      ]
    },
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "hex": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]*$"
    },
    "receipt": {
      "type": "object",
      "description": "TrustRail compliance receipt returned by trustrail_preflight or trustrail_attach_transaction."
    },
    "signedReceipt": {
      "type": "object",
      "description": "EIP-712 signed TrustRail receipt returned by trustrail_sign_receipt."
    },
    "attachTransactionInput": {
      "type": "object",
      "required": ["receipt", "txHash"],
      "properties": {
        "receipt": { "$ref": "#/definitions/receipt" },
        "txHash": { "type": "string", "minLength": 3 },
        "status": {
          "type": "string",
          "enum": ["broadcast", "confirmed", "failed"],
          "default": "confirmed"
        }
      }
    },
    "verifyReceiptInput": {
      "type": "object",
      "required": ["receipt"],
      "properties": {
        "receipt": { "$ref": "#/definitions/receipt" }
      }
    },
    "signReceiptInput": {
      "type": "object",
      "required": ["receipt"],
      "properties": {
        "receipt": { "$ref": "#/definitions/receipt" },
        "agentWallet": { "$ref": "#/definitions/address" },
        "issuerPrivateKey": {
          "type": "string",
          "pattern": "^0x[a-fA-F0-9]{64}$"
        },
        "chainId": {
          "type": "integer",
          "minimum": 1
        },
        "expiresInSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "nonce": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verifySignedReceiptInput": {
      "type": "object",
      "required": ["signedReceipt"],
      "properties": {
        "signedReceipt": { "$ref": "#/definitions/signedReceipt" },
        "authorizedIssuers": {
          "type": "array",
          "items": { "$ref": "#/definitions/address" }
        }
      }
    },
    "guardTransactionInput": {
      "type": "object",
      "required": ["signedReceipt", "tx"],
      "properties": {
        "signedReceipt": { "$ref": "#/definitions/signedReceipt" },
        "tx": {
          "type": "object",
          "required": ["from", "to", "chainId"],
          "properties": {
            "from": { "$ref": "#/definitions/address" },
            "to": { "$ref": "#/definitions/address" },
            "chainId": {
              "type": "integer",
              "minimum": 1
            },
            "valueUsd": {
              "type": "number",
              "minimum": 0
            },
            "data": { "$ref": "#/definitions/hex" }
          }
        },
        "authorizedIssuers": {
          "type": "array",
          "items": { "$ref": "#/definitions/address" }
        },
        "allowWarn": { "type": "boolean" }
      }
    },
    "registryV2Input": {
      "type": "object",
      "required": ["signedReceipt"],
      "properties": {
        "signedReceipt": { "$ref": "#/definitions/signedReceipt" }
      }
    }
  }
}
